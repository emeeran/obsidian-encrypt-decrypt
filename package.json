{
  "name": "obsidian-note-encryptor",
  "version": "1.0.0",
  "description": "Encrypt individual notes with password protection using AES-256-GCM",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "encryption",
    "security",
    "aes-256"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.17.3",
    "obsidian": "latest",
    "tslib": "^2.4.0",
    "typescript": "^4.7.4"
  }
}
